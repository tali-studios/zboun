NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: Google Search Console → HTML tag verification (content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Maps (location picker + "restaurants near me") — restrict key by HTTP referrer in Google Cloud
# NEVER commit real keys. Rotate any key that was shared in chat/email.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyD6vDZg0KIoY9DJK96gKLv1FXuIimMpxXQ
# Default search radius on home page (users can adjust via slider, 3–50 km)
NEXT_PUBLIC_DEFAULT_DELIVERY_RADIUS_KM=10

# Server-only: Supabase Dashboard → Settings → API → service_role (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MENU_BUCKET=menu-items
SUPABASE_LOGO_BUCKET=restaurant-logos

# SMTP (onboarding, renewal contract PDF, subscription reminders)
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Subscription reminders → restaurant admin + ops inbox (default: zbounlb@outlook.com)
ZBOUN_OPS_EMAIL=zbounlb@outlook.com

# Vercel Cron → GET /api/cron/subscription-reminders (daily 07:00 UTC; Hobby plan limit; Bearer <secret>)
CRON_SECRET=

# npm run test:smoke — optional overrides
# TEST_BASE_URL=http://localhost:3000
# TEST_RESTAURANT_SLUG=your-restaurant-slug

# npm run seed:superadmin — use quotes if password contains # or $
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin
