NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Auth sessions: stay signed in on the same device until sign-out (see src/lib/supabase/session.ts).
# In Supabase Dashboard → Authentication → Sessions: disable strict time-box / inactivity limits
# if users are logged out unexpectedly.
NEXT_PUBLIC_APP_URL=https://zboun.net

# Optional: Google Search Console → HTML tag verification (content value only)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Google Maps (location picker + "restaurants near me") — restrict key by HTTP referrer in Google Cloud
# NEVER commit real keys. Rotate any key that was shared in chat/email.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyD6vDZg0KIoY9DJK96gKLv1FXuIimMpxXQ
# Default search radius on home page (users can adjust via slider, 3–50 km)
NEXT_PUBLIC_DEFAULT_DELIVERY_RADIUS_KM=10

# Server-only: Supabase Dashboard → Settings → API → service_role (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_MENU_BUCKET=menu-items
SUPABASE_LOGO_BUCKET=restaurant-logos

# SMTP via Zoho Mail (onboarding, OTP, renewal contract PDF, subscription reminders)
# Create no-reply@zboun.net as an alias of admin@zboun.net in Zoho, then use admin credentials below.
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USER=admin@zboun.net
SMTP_PASS=
SMTP_FROM=no-reply@zboun.net
SMTP_FROM_NAME=Zboun
# Optional: where replies to automated emails should go
SMTP_REPLY_TO=admin@zboun.net

# Subscription reminders → restaurant admin + ops inbox
# Platform payment reminders (domain renewals, etc.) also go to ZBOUN_OPS_EMAIL.
ZBOUN_OPS_EMAIL=admin@zboun.net

# Vercel Cron → GET /api/cron/subscription-reminders (daily 07:00 UTC; Hobby plan limit; Bearer <secret>)
CRON_SECRET=

# npm run test:smoke — optional overrides
# TEST_BASE_URL=http://localhost:3000
# TEST_RESTAURANT_SLUG=your-restaurant-slug

# npm run seed:superadmin — use quotes if password contains # or $
SUPERADMIN_EMAIL=
SUPERADMIN_PASSWORD=
SUPERADMIN_NAME=Super Admin
